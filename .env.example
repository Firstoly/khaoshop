# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-random-secret-min-32-chars-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# Cloudinary (รูปภาพ)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Pusher (Realtime - สมัครฟรีที่ pusher.com)
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# Email (Resend - สมัครฟรีที่ resend.com สำหรับ Reset Password)
RESEND_API_KEY="re_your_api_key"

# Cron Secret (สุ่มตัวอักษรมาใส่ เช่น openssl rand -hex 32)
CRON_SECRET="your-cron-secret-random-string"

# Neon Direct URL (ใช้คู่กับ DATABASE_URL)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
